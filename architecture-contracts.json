      "protocol": "https",
      "auth": "BLOB_READ_WRITE_TOKEN_OR_CLIENT_UPLOAD_TOKEN",
      "contract": "blob_ref and blob_url schemes in apps/web/src/lib/blob.ts",
      "caller": "apps/web/src/lib/blob.ts",
      "failure_verdict": "STORAGE_AUTH_FAILED",
